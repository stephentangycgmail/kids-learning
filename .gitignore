# Kids Learning - Git ignore rules

# Secrets and local configuration
backend/config.json
.env
.env.*
*.key
*.pem
secrets.json

# Python cache and virtual environments
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.venv/
venv/
env/
ENV/

# Build / deployment artifacts
deploy/*.zip
*.log
*.tmp

# Node / frontend tooling cache, if added later
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE / editor
.vscode/
.idea/

# Windows / macOS system files
Thumbs.db
Desktop.ini
.DS_Store
