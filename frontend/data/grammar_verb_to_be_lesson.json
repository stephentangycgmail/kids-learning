{
  "id": "P4_VERB_TO_BE",
  "title": "Verb to be",
  "level": "Primary 4",
  "explanation_en": "Use am, is and are to describe people, animals, places and things. Use am with I, is with he, she, it or one thing, and are with you, we, they or plural things.",
  "explanation_zh": "am、is 和 are 用來描述人、動物、地方和物件。I 配 am；he、she、it 或單數配 is；you、we、they 或複數配 are。",
  "structure": {
    "learning_objective_en": "I can choose am, is or are in statements, negative sentences and questions.",
    "learning_objective_zh": "我能在陳述句、否定句和疑問句中正確選擇 am、is 或 are。",
    "positive": "Subject + am/is/are + description.",
    "negative": "Subject + am not/isn't/aren't + description.",
    "question": "Am/Is/Are + subject + description?"
  },
  "spelling_rules": [
    {"rule": "Use am with I.", "example": "I am happy."},
    {"rule": "Use is with he, she, it or one thing.", "example": "She is kind."},
    {"rule": "Use are with you, we, they or plural things.", "example": "They are ready."},
    {"rule": "Use isn't as the short form of is not.", "example": "is not → isn't"},
    {"rule": "Use aren't as the short form of are not.", "example": "are not → aren't"}
  ],
  "signal_words": ["am", "is", "are", "isn't", "aren't"],
  "common_mistakes": [
    {"wrong": "I is happy.", "correct": "I am happy."},
    {"wrong": "She are my friend.", "correct": "She is my friend."},
    {"wrong": "They is at school.", "correct": "They are at school."}
  ],
  "keywords": ["am", "is", "are", "am not", "isn't", "aren't", "Is", "Are"],
